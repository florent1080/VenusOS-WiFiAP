#!/bin/bash

# VenusOS-WiFiAP setup script
# WiFi Access Point with NAT internet sharing for Venus OS (RPi3 BCM43438)
#
# This script installs/uninstalls:
#   - wifi-ap.conf (default config, preserved on reinstall)
#   - Replaces /service/hostapd/run with a custom script that:
#       * creates ap0 virtual interface (not done by native hostapd-run on RPi3)
#       * writes /run/hostapd.conf with our SSID/PSK
#       * sets up NAT and DHCP
#       * runs hostapd in foreground (supervise manages it)
#   - Writes a dummy serial-number so venus-platform publishes
#     /Services/AccessPoint/* D-Bus paths (needed for UI visibility)

packageDir="$(dirname "$(realpath "$0")")"
INSTALL_DIR="/data/wifi-ap"
CONF_SRC="$packageDir/wifi-ap.conf"
CONF_DST="$INSTALL_DIR/wifi-ap.conf"

#### following line incorporates helper resources into this script
source "/data/SetupHelper/HelperResources/IncludeHelpers"
#### end of lines to include helper resources

set +e

#### running manually and target just install or uninstall
if [ $scriptAction == 'NONE' ] ; then
    echo
    echo "This package creates a WiFi Access Point on Venus OS (RPi3)"
    echo "Edit /data/wifi-ap/wifi-ap.conf to set SSID and password"
    echo
    scriptAction=$(promptForAction)
fi

# --- INSTALL -----------------------------------------------------------------
if [ $scriptAction == 'INSTALL' ] ; then
    logMessage "installing VenusOS-WiFiAP"

    # Ensure hostapd binary is present
    if ! command -v hostapd >/dev/null 2>&1 && [ ! -x /usr/sbin/hostapd ] && [ ! -x /usr/bin/hostapd ]; then
        logMessage "hostapd not found, attempting install via opkg"
        opkg update >/dev/null 2>&1 || true
        if opkg install hostapd >/dev/null 2>&1; then
            logMessage "hostapd installed"
        else
            logMessage "WARNING: unable to install hostapd automatically"
            logMessage "Install manually: opkg update && opkg install hostapd"
        fi
    fi

    # Create install directory and install config (preserve existing)
    mkdir -p "$INSTALL_DIR"
    if [ ! -f "$CONF_DST" ]; then
        cp "$CONF_SRC" "$CONF_DST"
        logMessage "default config installed: $CONF_DST"
    else
        logMessage "config already exists, preserved: $CONF_DST"
    fi

    # --- Fix: write a dummy serial-number so venus-platform publishes
    # /Services/AccessPoint/* D-Bus paths on DIY RPi3 builds.
    # On real Victron GX devices the serial is in EEPROM; on RPi3 DIY
    # it is absent and hostapd-run aborts immediately, causing the UI AP
    # section to never appear.
    SERIAL_FILE="/data/venus/serial-number"
    if [ ! -s "$SERIAL_FILE" ]; then
        UNIQUE_ID="$(cat /data/venus/unique-id 2>/dev/null | tr -d '\n' | tr -d '\r' || true)"
        FAKE_SERIAL="RPi3-${UNIQUE_ID:-000000000000}"
        echo "$FAKE_SERIAL" > "$SERIAL_FILE"
        logMessage "wrote dummy serial-number: $FAKE_SERIAL"
    else
        logMessage "serial-number already set: $(cat $SERIAL_FILE)"
    fi

    # --- Replace /service/hostapd/run with our custom script.
    # The native hostapd-run requires serial-number AND ap0 to already exist,
    # and uses a fixed SSID format (venus-SERIAL-XXX) ignoring our config.
    # Our replacement: creates ap0, configures networking, runs hostapd with
    # the SSID/PSK from wifi-ap.conf.
    # venus-platform monitors the native /service/hostapd supervise state and
    # reads /run/hostapd.conf => publishes AccessPoint/* D-Bus paths => UI shows AP.
    HOSTAPD_RUN_SRC="$packageDir/services/hostapd-native/run"
    HOSTAPD_RUN_DST="/service/hostapd/run"
    HOSTAPD_RUN_ORIG="$INSTALL_DIR/hostapd-run.orig"

    if [ -f "$HOSTAPD_RUN_DST" ] && [ ! -f "$HOSTAPD_RUN_ORIG" ]; then
        cp "$HOSTAPD_RUN_DST" "$HOSTAPD_RUN_ORIG"
        logMessage "backed up original $HOSTAPD_RUN_DST -> $HOSTAPD_RUN_ORIG"
    fi

    if [ -f "$HOSTAPD_RUN_SRC" ]; then
        cp "$HOSTAPD_RUN_SRC" "$HOSTAPD_RUN_DST"
        chmod +x "$HOSTAPD_RUN_DST"
        logMessage "installed custom /service/hostapd/run"
    else
        logMessage "WARNING: $HOSTAPD_RUN_SRC not found"
    fi

    # Stop any stale wifi-ap custom service and enable native hostapd
    svc -d /service/wifi-ap 2>/dev/null || true
    rm -f /service/hostapd/down 2>/dev/null || true
    svc -u /service/hostapd 2>/dev/null || true
    logMessage "native hostapd service enabled"

    logMessage "VenusOS-WiFiAP install complete"
    logMessage "AP SSID and password read from $CONF_DST"
fi

# --- UNINSTALL ---------------------------------------------------------------
if [ $scriptAction == 'UNINSTALL' ] ; then
    logMessage "uninstalling VenusOS-WiFiAP"

    # Stop native hostapd and restore original run script
    svc -d /service/hostapd 2>/dev/null || true
    touch /service/hostapd/down
    HOSTAPD_RUN_ORIG="$INSTALL_DIR/hostapd-run.orig"
    if [ -f "$HOSTAPD_RUN_ORIG" ]; then
        cp "$HOSTAPD_RUN_ORIG" /service/hostapd/run
        chmod +x /service/hostapd/run
        logMessage "original /service/hostapd/run restored"
    fi

    # Clean up ap0 interface, NAT, DHCP
    ip link set ap0 down 2>/dev/null || true
    iw dev ap0 del 2>/dev/null || true
    kill "$(cat /var/run/dnsmasq-ap0.pid 2>/dev/null)" 2>/dev/null || true
    UPSTREAM_CONF="$(grep '^UPSTREAM=' "$CONF_DST" 2>/dev/null | cut -d= -f2 | tr -d '"' | tr -d "'" || echo wwan0)"
    UPSTREAM="${UPSTREAM_CONF:-wwan0}"
    iptables -t nat -D POSTROUTING -o "$UPSTREAM" -j MASQUERADE 2>/dev/null || true
    iptables -D FORWARD -i ap0 -o "$UPSTREAM" -j ACCEPT 2>/dev/null || true
    iptables -D FORWARD -i "$UPSTREAM" -o ap0 -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || true

    # wifi-ap.conf preserved (user data)
    logMessage "config preserved: $CONF_DST"
    logMessage "VenusOS-WiFiAP uninstalled"
fi

# Let SetupHelper handle service install/uninstall for wifi-ap
endScript INSTALL_SERVICES