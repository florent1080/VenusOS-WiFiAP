#!/bin/sh
# VenusOS-WiFiAP - placeholder service (kept for SetupHelper compatibility)
#
# WiFi AP is now managed by the native /service/hostapd service,
# controlled via venus-platform: Settings > Connectivity > Access Point.
# Toggle the AP from the Victron UI (Settings/Services/AccessPoint D-Bus setting).
#
# This service does nothing - it is a no-op kept so SetupHelper can track
# the package status in /service/wifi-ap/.
exec 2>&1
exec sleep infinity

# -- Load config --------------------------------------------------------------
CONF=/data/wifi-ap/wifi-ap.conf
[ -f "$CONF" ] && . "$CONF"

SSID="${SSID:-ZeVan}"
PASSWORD="${PASSWORD:-victron1234}"
CHANNEL="${CHANNEL:-1}"
AP_IP="${AP_IP:-192.168.0.1}"
DHCP_START="${DHCP_START:-192.168.0.100}"
DHCP_END="${DHCP_END:-192.168.0.200}"
DHCP_LEASE="${DHCP_LEASE:-2m}"
UPSTREAM="${UPSTREAM:-wwan0}"
IFACE="wlan0"
AP_IFACE="ap0"
HOSTAPD_BIN="$(command -v hostapd 2>/dev/null || true)"

[ -z "$HOSTAPD_BIN" ] && [ -x /usr/sbin/hostapd ] && HOSTAPD_BIN="/usr/sbin/hostapd"
[ -z "$HOSTAPD_BIN" ] && [ -x /usr/bin/hostapd ] && HOSTAPD_BIN="/usr/bin/hostapd"

if [ -z "$HOSTAPD_BIN" ]; then
    echo "wifi-ap: ERROR - hostapd not found"
    echo "wifi-ap: install with: opkg update && opkg install hostapd"
    sleep 30
    exit 1
fi

echo "wifi-ap: starting - SSID=$SSID IP=$AP_IP upstream=$UPSTREAM"

# -- Unblock WiFi (rfkill) ----------------------------------------------------
rfkill unblock wifi 2>/dev/null || true

# -- Clean up any previous ap0 state -----------------------------------------
ip link set "$AP_IFACE" down 2>/dev/null || true
iw dev "$AP_IFACE" del 2>/dev/null || true
sleep 1

# -- Bring wlan0 down to release the PHY before creating ap0 -----------------
# NOTE: do NOT call connmanctl disable wifi (causes soft rfkill).
# Connman will try to bring wlan0 back up but fail once ap0 holds the PHY.
echo "wifi-ap: bringing $IFACE down to release PHY"
ip link set "$IFACE" down 2>/dev/null || true
sleep 1

# -- Create ap0 virtual AP interface -----------------------------------------
echo "wifi-ap: creating $AP_IFACE (type __ap)"
if ! iw dev "$IFACE" interface add "$AP_IFACE" type __ap; then
    echo "wifi-ap: ERROR - failed to create $AP_IFACE - retrying in 5s"
    sleep 5
    exit 1
fi
ip link set "$AP_IFACE" up
ip addr flush dev "$AP_IFACE" 2>/dev/null || true
ip addr add "$AP_IP/24" dev "$AP_IFACE"
echo "wifi-ap: $AP_IFACE created with IP $AP_IP"

# -- Write hostapd config -----------------------------------------------------
cat > /run/hostapd.conf <<EOF
interface=$AP_IFACE
driver=nl80211
ssid=$SSID
hw_mode=g
channel=$CHANNEL
macaddr_acl=0
auth_algs=1
ignore_broadcast_ssid=0
wpa=2
wpa_passphrase=$PASSWORD
wpa_key_mgmt=WPA-PSK
rsn_pairwise=CCMP
EOF

# -- Enable NAT ---------------------------------------------------------------
echo "wifi-ap: enabling NAT ($AP_IFACE -> $UPSTREAM)"
echo 1 > /proc/sys/net/ipv4/ip_forward
iptables -t nat -D POSTROUTING -o "$UPSTREAM" -j MASQUERADE 2>/dev/null || true
iptables -D FORWARD -i "$AP_IFACE" -o "$UPSTREAM" -j ACCEPT 2>/dev/null || true
iptables -D FORWARD -i "$UPSTREAM" -o "$AP_IFACE" -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || true
iptables -t nat -A POSTROUTING -o "$UPSTREAM" -j MASQUERADE
iptables -A FORWARD -i "$AP_IFACE" -o "$UPSTREAM" -j ACCEPT
iptables -A FORWARD -i "$UPSTREAM" -o "$AP_IFACE" -m state --state RELATED,ESTABLISHED -j ACCEPT

# -- Start dnsmasq for DHCP on ap0 -------------------------------------------
echo "wifi-ap: starting dnsmasq DHCP ($DHCP_START-$DHCP_END)"
PID_DNS=/var/run/dnsmasq-ap0.pid
kill "$(cat $PID_DNS 2>/dev/null)" 2>/dev/null || true
dnsmasq \
    --interface="$AP_IFACE" \
    --bind-interfaces \
    --dhcp-range="$DHCP_START,$DHCP_END,$DHCP_LEASE" \
    --dhcp-option=3,"$AP_IP" \
    --dhcp-option=6,8.8.8.8,8.8.4.4 \
    --no-resolv \
    --port=0 \
    --pid-file="$PID_DNS" \
    2>&1 || true

echo "wifi-ap: launching hostapd on $AP_IFACE (SSID=$SSID)"
exec "$HOSTAPD_BIN" /run/hostapd.conf
